# Zinga Linga Educational Platform - Environment Variables

# API Configuration
REACT_APP_API_URL=https://api.zingalinga.com
REACT_APP_CDN_URL=https://cdn.zingalinga.com

# DRM Configuration
REACT_APP_DRM_LICENSE_URL=https://drm.zingalinga.com
REACT_APP_DRM_CERTIFICATE_URL=https://drm.zingalinga.com/certificate

# Content Delivery Network
REACT_APP_HLS_BASE_URL=https://cdn.zingalinga.com/hls
REACT_APP_PROGRESSIVE_BASE_URL=https://cdn.zingalinga.com/mp4

# Authentication
REACT_APP_AUTH_DOMAIN=auth.zingalinga.com
REACT_APP_JWT_SECRET=your-jwt-secret-key

# Analytics & Monitoring
REACT_APP_ANALYTICS_URL=https://analytics.zingalinga.com
REACT_APP_MONITORING_URL=https://monitoring.zingalinga.com

# Payment Processing
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_client_id

# Content Protection
REACT_APP_WATERMARK_ENABLED=true
REACT_APP_SCREENSHOT_PROTECTION=true
REACT_APP_DOWNLOAD_PROTECTION=true

# Development Settings
REACT_APP_DEBUG_MODE=false
REACT_APP_MOCK_DRM=false
REACT_APP_BYPASS_AUTH=false